# Copy to .env (gitignored) and fill in. Variables are grouped by what
# they enable — only the "Required" block is needed to boot the service;
# the rest gate individual features (AI chat, contact form, billing, etc.).

# -----------------------------------------------------------------------
# Required — service won't start cleanly without these.
# -----------------------------------------------------------------------

# Mongo connection string. The docker-compose stack in /infra brings up a
# local instance at the URL below.
MONGO_CONNECT=mongodb://admin:password@localhost:27017/sumobubble-dev?authSource=admin

# Symmetric secret used by NextAuth to sign JWT session tokens. Generate
# with: openssl rand -base64 32
JWT_SECRET=

# The public URL the service is served from. Used by NextAuth for OAuth
# callback URLs.
NEXTAUTH_URL=http://localhost:3000

# Auth0 application credentials. Create an app at https://auth0.com,
# then put http://localhost:3000/api/auth/callback/auth0 in its
# "Allowed Callback URLs".
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_ISSUER=your-tenant.us.auth0.com

# -----------------------------------------------------------------------
# Optional — feature-gated. Leave blank to disable that feature.
# -----------------------------------------------------------------------

# AI chat (Ask AI). Free-tier key at https://aistudio.google.com.
GEMINI_API_KEY=

# Contact / info-request form. reCAPTCHA v3 — the matching SITE key lives
# in apps/wc/.env as VITE_RECAPTCHA_SITE_KEY.
RECAPTCHA_SECRET=

# SMTP for contact-form mail delivery. With Gmail, use an App Password
# (not your account password).
SUMOBUBBLE_MAIL_HOST=smtp.gmail.com
SUMOBUBBLE_MAIL_FROM=
SUMOBUBBLE_MAIL_AUTH=

# Stripe (subscriptions). Webhook secret comes from
#   stripe listen --forward-to localhost:3000/api/subscribe
STRIPE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_HOME_ID=
STRIPE_CONSOLE_ID=
STRIPE_CHAT_PRODUCTS=

# Production publish target (S3-compatible). In dev, publish writes to a
# local file under apps/wc/dev-sites/ instead — these are only read when
# NODE_ENV=production.
SPACES_BUCKET=
SPACES_ENDPOINT=
SPACES_REGION=
SPACES_KEY=
SPACES_SECRET=

# Public URL where the wc bundle is hosted. Shown in the "Deploy Using
# Code" snippet on the Site Setup page.
NEXT_PUBLIC_SCRIPT_URL=

# Optional dev override — where /api/site/:id/publish writes the JSON in
# non-production. Defaults to ../wc/dev-sites/dev-site.json.
# DEV_PUBLISH_PATH=

# Web component build-time configuration.
# Copy to .env.local (gitignored) and override as needed.
# All values must be prefixed VITE_ to be exposed to the bundle.

# Public reCAPTCHA v3 site key. Site keys are visible in the browser
# and are not secret; the SECRET key lives only on the service backend.
VITE_RECAPTCHA_SITE_KEY=6LdHNPIkAAAAAHi7HsTDq-RFRKGFMwt6ZOWSFEGn

# Where to fetch published site configs from (no trailing slash).
# Production: https://sumobubble-space.nyc3.digitaloceanspaces.com/sites
# Dev: /sites — relative to the wc's origin; dev-server.js serves
#       ./dev-sites at /sites, and the service writes the published
#       JSON there in dev mode (one file: dev-site.json, last write wins).
VITE_SITES_BASE_URL=https://sumobubble-space.nyc3.digitaloceanspaces.com/sites

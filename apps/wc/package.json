  "devDependencies": {
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/vite": "^4.3.0",
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.2",
    "http-server": "^14.1.1",
    "prettier": "^3.8.3",

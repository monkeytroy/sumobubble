{
  "name": "sumobubble",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "turbo run dev",
    "dev:service": "pnpm --filter sumobubble-service dev",
    "dev:wc": "pnpm --filter sumobubble-app dev",
    "dev:infra": "pnpm --filter @sumobubble/infra dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "infra:stop": "pnpm --filter @sumobubble/infra stop",
    "infra:reset": "pnpm --filter @sumobubble/infra reset"
  },
  "devDependencies": {
    "turbo": "^2.5.8"
  }
}
